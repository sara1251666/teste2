<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36" version="29.6.3">
  <diagram name="Página-1" id="FPkCAd1oCl9R3Za713HM">
    <mxGraphModel dx="7058" dy="1240" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="4681" pageHeight="3300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam packageStyle rectangle\n\npackage \&quot;utils\&quot; &lt;&lt;Folder&gt;&gt; {\n    class ImportadorCSV {\n        + {static} importarDados(caminho : String, repo : RepositorioDados) : void\n    }\n    class ExportadorCSV {\n        + {static} exportarDados(repo : RepositorioDados) : void\n    }\n    class Estatisticas {\n        + {static} calcularMediaUCsDocente(doc : Docente, repo : RepositorioDados) : double\n        + {static} contarAlunosAvaliadosDoDocente(doc : Docente, repo : RepositorioDados) : int\n    }\n    class EmailGenerator {\n        + {static} gerarEmailEstudante(numMec : int) : String\n    }\n    class PasswordGenerator {\n        + {static} generatePassword() : String\n    }\n    class Validador {\n        + {static} isNomeValido(nome : String) : boolean\n        + {static} isNifValido(nif : String) : boolean\n    }\n}\n\npackage \&quot;view\&quot; &lt;&lt;Folder&gt;&gt; {\n    class GestorView {\n        + mostrarMenuPrincipal() : int\n        + mostrarMenuRelatorios() : int\n        + pedirInputString(mensagem : String) : String\n        + mostrarMensagem(mensagem : String) : void\n    }\n    class DocenteView {\n        + mostrarMenuPrincipal() : int\n        + mostrarMenuAtualizarDados() : int\n        + pedirInputString(mensagem : String) : String\n        + mostrarMensagem(mensagem : String) : void\n    }\n    class EstudanteView {\n        + mostrarMenuPrincipal() : int\n        + pedirInputString(mensagem : String) : String\n        + mostrarMensagem(mensagem : String) : void\n    }\n}\n\npackage \&quot;model\&quot; &lt;&lt;Folder&gt;&gt; {\n    abstract class Utilizador {\n        # email : String\n        # password : String\n        # nome : String\n        # nif : String\n        # morada : String\n        # dataNascimento : String\n    }\n\n    class RepositorioDados {\n        - anoAtual : int\n        - totalEstudantes : int\n        - totalDocentes : int\n        - totalCursos : int\n        - totalUcs : int\n        + avancarAno() : void\n        + obterEstudantesPorUC(siglaUC : String) : Estudante[]\n        + adicionarEstudante(est : Estudante) : void\n        + adicionarUnidadeCurricular(uc : UnidadeCurricular) : boolean\n    }\n\n    class Estudante {\n        - numeroMecanografico : int\n        - anoPrimeiraInscricao : int\n        - anoCurricular : int\n        - anoFrequencia : int\n        - totalAvaliacoes : int\n        - totalHistorico : int\n        + processarFimDeAno() : void\n        + temAproveitamentoParaProgredir() : boolean\n        + teveAprovacao(siglaUC : String) : boolean\n        + jaConcluiuUC(siglaUC : String) : boolean\n        + estaInscrito(siglaUC : String) : boolean\n        + obterNumeroProximaAvaliacao(siglaUC : String) : int\n        + adicionarNota(uc : UnidadeCurricular, nota : double, ano : int) : boolean\n        + arquivarAvaliacoes() : void\n    }\n\n    class Docente {\n        - sigla : String\n        - totalUcsResponsavel : int\n        - totalUcsLecionadas : int\n        + adicionarUcLecionada(uc : UnidadeCurricular) : void\n    }\n\n    class Gestor {\n        - cargo : String\n        - telefone : String\n        + criarEstudante(...) : Estudante\n    }\n\n    class Curso {\n        - sigla : String\n        - nome : String\n        - duracaoAnos : int\n        - totalUCs : int\n        + adicionarUnidadeCurricular(uc : UnidadeCurricular) : void\n    }\n\n    class Departamento {\n        - sigla : String\n        - nome : String\n        - totalCursos : int\n        + adicionarCurso(c : Curso) : void\n    }\n\n    class UnidadeCurricular {\n        - sigla : String\n        - nome : String\n        - anoCurricular : int\n    }\n\n    class PercursoAcademico {\n        - totalUcsInscrito : int\n        - totalAvaliacoes : int\n        + limparInscricoesAtivas() : void\n        + inscreverEmUc(uc : UnidadeCurricular) : void\n    }\n\n    class Avaliacao {\n        - anoLetivo : int\n        - resultados : double[]\n        - totalAvaliacoesLancadas : int\n        + adicionarResultado(nota : double) : boolean\n        + calcularMedia() : double\n        + getTotalAvaliacoesLancadas() : int\n    }\n}\n\npackage \&quot;controller\&quot; &lt;&lt;Folder&gt;&gt; {\n    class GestorController {\n        + iniciarMenu() : void\n        - gerirDepartamentos() : void\n        - gerirCursos() : void\n        - gerirRelatorios() : void\n    }\n    class DocenteController {\n        + iniciarMenu() : void\n        - gerirAvaliacoes() : void\n        - atualizarDadosDocente() : void\n        - mostrarEstatisticasDocente() : void\n    }\n    class EstudanteController {\n        + iniciarMenu() : void\n        - verDadosEstudante() : void\n        - atualizarDadosEstudante() : void\n        - verPercursoAcademico() : void\n    }\n    class MainController {\n        + iniciarSistema() : void\n    }\n}\n\n&#39; --- HERANÇAS (Models) ---\nUtilizador &lt;|-- Estudante\nUtilizador &lt;|-- Docente\nUtilizador &lt;|-- Gestor\n\n&#39; --- ASSOCIAÇÕES (Models) ---\nRepositorioDados \&quot;1\&quot; *-- \&quot;0..*\&quot; Estudante : gere &gt;\nRepositorioDados \&quot;1\&quot; *-- \&quot;0..*\&quot; Docente : gere &gt;\nRepositorioDados \&quot;1\&quot; *-- \&quot;0..*\&quot; Curso : gere &gt;\nRepositorioDados \&quot;1\&quot; *-- \&quot;0..*\&quot; Departamento : gere &gt;\n\nDepartamento \&quot;1\&quot; *-- \&quot;0..*\&quot; Curso : tem &gt;\nCurso \&quot;1\&quot; *-- \&quot;0..*\&quot; UnidadeCurricular : contem &gt;\nDocente \&quot;1\&quot; o-- \&quot;0..*\&quot; UnidadeCurricular : leciona &gt;\nUnidadeCurricular \&quot;0..*\&quot; --&gt; \&quot;1\&quot; Docente : responsavel &gt;\n\nEstudante \&quot;1\&quot; *-- \&quot;1\&quot; PercursoAcademico : possui &gt;\nEstudante \&quot;1\&quot; *-- \&quot;0..*\&quot; Avaliacao : avaliacoesAtuais &gt;\nEstudante \&quot;1\&quot; *-- \&quot;0..*\&quot; Avaliacao : historico &gt;\nEstudante \&quot;0..*\&quot; --&gt; \&quot;1\&quot; Curso : matriculado em &gt;\n\nPercursoAcademico \&quot;1\&quot; o-- \&quot;0..*\&quot; UnidadeCurricular : ucsInscrito &gt;\nAvaliacao \&quot;0..*\&quot; --&gt; \&quot;1\&quot; UnidadeCurricular : refere-se a &gt;\n\n&#39; --- RELAÇÕES MVC (Controllers com Views e Models) ---\nGestorController --&gt; \&quot;1\&quot; GestorView : usa &gt;\nGestorController --&gt; \&quot;1\&quot; RepositorioDados : manipula &gt;\nGestorController --&gt; \&quot;1\&quot; Gestor : gestorLogado &gt;\n\nDocenteController --&gt; \&quot;1\&quot; DocenteView : usa &gt;\nDocenteController --&gt; \&quot;1\&quot; RepositorioDados : manipula &gt;\nDocenteController --&gt; \&quot;1\&quot; Docente : docenteLogado &gt;\n\nEstudanteController --&gt; \&quot;1\&quot; EstudanteView : usa &gt;\nEstudanteController --&gt; \&quot;1\&quot; RepositorioDados : manipula &gt;\nEstudanteController --&gt; \&quot;1\&quot; Estudante : estudanteLogado &gt;\n\nMainController --&gt; \&quot;1\&quot; RepositorioDados : carrega &gt;\nMainController ..&gt; GestorController : instancia &gt;\nMainController ..&gt; DocenteController : instancia &gt;\nMainController ..&gt; EstudanteController : instancia &gt;\n\n&#39; --- RELAÇÕES COM UTILS (Dependências) ---\nMainController ..&gt; ImportadorCSV : usa &gt;\nGestorController ..&gt; EmailGenerator : usa &gt;\nGestorController ..&gt; PasswordGenerator : usa &gt;\nDocenteController ..&gt; Estatisticas : usa &gt;\nDocenteController ..&gt; Validador : usa &gt;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="yP2_Q7OuSbIsj8vUxe-p-1">
