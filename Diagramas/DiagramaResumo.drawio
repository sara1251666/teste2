        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\npackage \&quot;model\&quot; {\n\n    abstract class Utilizador {\n        - email : String\n        - password : String\n        - nome : String\n        - nif : String\n        - morada : String\n        - dataNascimento : String\n    }\n\n    class Estudante {\n        - numeroMecanografico : int\n        - anoPrimeiraInscricao : int\n        - anoCurricular : int\n        - anoFrequencia : int\n        - totalAvaliacoes : int\n        - totalHistorico : int\n        + processarFimDeAno() : void\n        + temAproveitamentoParaProgredir() : boolean\n        + teveAprovacao(siglaUC : String) : boolean\n        + jaConcluiuUC(siglaUC : String) : boolean\n        + estaInscrito(siglaUC : String) : boolean\n        + obterNumeroProximaAvaliacao(siglaUC : String) : int\n        + adicionarNota(uc : UnidadeCurricular, nota : double, anoAtual : int) : boolean\n        + arquivarAvaliacoes() : void\n    }\n\n    class Docente {\n        - sigla : String\n        - totalUcsResponsavel : int\n        - totalUcsLecionadas : int\n        + adicionarUcLecionada(uc : UnidadeCurricular) : void\n    }\n\n    class Gestor {\n        - cargo : String\n    }\n\n    class Curso {\n        - sigla : String\n        - nome : String\n        - duracaoAnos : int\n        - totalUCs : int\n        + adicionarUnidadeCurricular(uc : UnidadeCurricular) : void\n    }\n\n    class UnidadeCurricular {\n        - sigla : String\n        - nome : String\n        - anoCurricular : int\n    }\n\n    class PercursoAcademico {\n        - totalUcsInscrito : int\n        - totalAvaliacoes : int\n        + limparInscricoesAtivas() : void\n        + inscreverEmUc(uc : UnidadeCurricular) : void\n    }\n\n    class Avaliacao {\n        - anoLetivo : int\n        - resultados : double[]\n        - totalAvaliacoesLancadas : int\n        + adicionarResultado(nota : double) : boolean\n        + calcularMedia() : double\n        + getTotalAvaliacoesLancadas() : int\n    }\n\n    class RepositorioDados {\n        - anoAtual : int\n        - totalEstudantes : int\n        + avancarAno() : void\n        + obterEstudantesPorUC(siglaUC : String) : Estudante[]\n    }\n\n    &#39; --- RELAÇÕES DE HERANÇA ---\n    Utilizador &lt;|-- Estudante\n    Utilizador &lt;|-- Docente\n    Utilizador &lt;|-- Gestor\n\n    &#39; --- RELAÇÕES DE ASSOCIAÇÃO E COMPOSIÇÃO ---\n    Estudante \&quot;1\&quot; *-- \&quot;1\&quot; PercursoAcademico : possui &gt;\n    Estudante \&quot;1\&quot; *-- \&quot;0..*\&quot; Avaliacao : avaliacoesAtuais &gt;\n    Estudante \&quot;1\&quot; *-- \&quot;0..*\&quot; Avaliacao : historico &gt;\n    Estudante \&quot;0..*\&quot; -up-&gt; \&quot;1\&quot; Curso : matriculado em &gt;\n\n    PercursoAcademico \&quot;1\&quot; o-- \&quot;0..*\&quot; UnidadeCurricular : ucsInscrito &gt;\n    \n    Avaliacao \&quot;0..*\&quot; --&gt; \&quot;1\&quot; UnidadeCurricular : refere-se a &gt;\n    \n    Curso \&quot;1\&quot; *-- \&quot;0..*\&quot; UnidadeCurricular : contem &gt;\n    \n    Docente \&quot;1\&quot; o-- \&quot;0..*\&quot; UnidadeCurricular : leciona &gt;\n    UnidadeCurricular \&quot;0..*\&quot; --&gt; \&quot;1\&quot; Docente : responsavel &gt;\n\n    RepositorioDados \&quot;1\&quot; *-- \&quot;0..*\&quot; Estudante : gere &gt;\n    RepositorioDados \&quot;1\&quot; *-- \&quot;0..*\&quot; Docente : gere &gt;\n    RepositorioDados \&quot;1\&quot; *-- \&quot;0..*\&quot; Curso : gere &gt;\n}\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="voUx9F4Gl2maNYTldhTh-1">
